# MongoDB connection string
# Development example:
# MONGO_URI=mongodb://localhost:27017/pdf-reader
# Production example:
# MONGO_URI=mongodb+srv://pdf_reader_app:strong_password@cluster.mongodb.net/pdf-reader?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/pdf-reader

# JWT secret
# MUST be replaced in production.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-64-char-random-secret

# Server port
PORT=5000

# Runtime environment
# Allowed values: development, production
NODE_ENV=development

# Frontend origin used by CORS in production
# Example: https://your-frontend.example.com
FRONTEND_URL=http://localhost:3000
